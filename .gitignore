# ============================================================
# Unreal Engine 5 — generated / local / transient
# ============================================================
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/

# Generated project files
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
.vs/
.vsconfig

# Plugin binaries (each dev builds locally)
Plugins/*/Binaries/
Plugins/*/Intermediate/

# ============================================================
# Unreal content — keep source assets, skip auto-generated
# ============================================================
